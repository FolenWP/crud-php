<?php
session_start();

if(isset($_SESSION["admin"])) {
    header("Location: admin.php");
    exit();
}

$error = "";

if($_SERVER["REQUEST_METHOD"] == "POST") {
    $email = $_POST["email"];
    $password = $_POST["password"];
    
    // Tus credenciales personalizadas
    if($email == "24160670@itoaxaca.edu.mx" && $password == "24160670Tso") {
        $_SESSION["admin"] = true;
        $_SESSION["usuario"] = $email;
        header("Location: admin.php");
        exit();
    } else {
        $error = "Credenciales incorrectas";
    }
}
?>
